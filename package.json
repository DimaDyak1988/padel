{
  "name": "padel_crm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.ts,.vue",
    "lint:fix": "eslint src --ext .js,.ts,.vue --fix",
    "type-check": "vue-tsc --noEmit",
    "type-check:watch": "vue-tsc --noEmit --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "gen:types": "source .env && npx supabase@2.20.0 gen types typescript --project-id $SUPABASE_PROJECT_ID --schema public > src/types/database.ts"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.5",
    "@supabase/supabase-js": "^2.106.2",
    "nanoid": "^5.1.11",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "valibot": "^1.4.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "^4.1.7",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.5"
  }
}
